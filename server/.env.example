# --- App ---
NODE_ENV=development
PORT=5002
API_ORIGIN=http://localhost:5002
FRONTEND_ORIGIN=http://localhost:5173
SOCKET_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# --- URLs & cookies ---
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# --- Auth / security ---
JWT_SECRET=change-me-in-prod
# CSRF cookie name is set by middleware; no token var needed here.

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chatforia

# --- Redis (optional; enables Socket.IO adapter & rate-limit stores) ---
REDIS_URL=redis://localhost:6379

# --- Email (Nodemailer). If empty, dev uses Ethereal/test transport automatically. ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=hello@chatforia.app

# --- File uploads ---
UPLOADS_DIR=./uploads
UPLOAD_TARGET=memory   # memory | local | disk

# --- Stripe (test) ---
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy
STRIPE_SKIP_SIG_CHECK=true


# Using Twilio #
# --- Telco providers (optional now; enable later) ---
# TELCO_PROVIDER=telnyx    # telnyx | bandwidth (default order if both present)
# Telnyx
# TELNYX_API_KEY=
# TELNYX_MESSAGING_PROFILE_ID=
# TELNYX_FROM_NUMBER=
# Bandwidth
# BANDWIDTH_ACCOUNT_ID=
# BANDWIDTH_USER_ID=
# BANDWIDTH_PASSWORD=
# BANDWIDTH_MESSAGING_APPLICATION_ID=
# BANDWIDTH_FROM_NUMBER=

# --- App links ---
APP_DOWNLOAD_URL=https://example.com/download
APP_ORIGIN=http://localhost:5173

# --- Status feature flag ---
STATUS_ENABLED=true

# --- Sentry (optional) ---
SENTRY_DSN=
SENTRY_TRACES_RATE=0.2
SENTRY_PROFILES_RATE=0.1

# --- Password reset ---
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# --- Google Play Billing / RTDN ---
# Android application ID registered in Google Play Console.
GOOGLE_PLAY_PACKAGE_NAME=

# Exact audience configured for the authenticated Pub/Sub push subscription.
GOOGLE_PLAY_RTDN_AUDIENCE=

# Service account expected to sign Pub/Sub push identity tokens.
GOOGLE_PLAY_RTDN_SERVICE_ACCOUNT_EMAIL=

# Keep disabled until Google Play credentials and reconciliation are ready.
GOOGLE_PLAY_RECONCILIATION_ENABLED=false
GOOGLE_PLAY_RECONCILIATION_INTERVAL_MS=3600000
GOOGLE_PLAY_RECONCILIATION_BATCH_SIZE=100
GOOGLE_PLAY_RECONCILIATION_STALE_MINUTES=360
