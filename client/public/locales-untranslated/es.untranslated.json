    "faq": {
      "title": "Pricing & plans FAQ",
      "free": {
        "q": "Is the Free plan really free?",
        "a": "Yes. The Free plan includes a Chatforia number, calling, and messaging with ads. You can stay on Free as long as you like, or upgrade to remove ads and unlock more features."
      },
      "plusPremium": {
        "q": "What’s the difference between Plus and Premium?",
        "a": "Plus removes ads and extends your message history — perfect for everyday use. Premium adds extra customization, AI tools for rewrites and replies, and priority support for heavy users."
      },
      "esim": {
        "q": "Where do eSIM data packs work?",
        "a": "Chatforia Mobile uses global eSIM coverage. Availability depends on your country and device. You’ll see supported options during activation inside the app."
      },
      "cancel": {
        "q": "Can I cancel or change plans anytime?",
        "a": "Yes. You can manage or cancel your subscription from the billing page in the app. Changes take effect at the end of your current billing period."
      },
      "family": {
        "q": "How do Family packs work?",
        "a": "Family packs create a shared data pool across multiple Chatforia accounts. One person pays the bill, and you can invite or remove members and set limits per person."
      }
    },
